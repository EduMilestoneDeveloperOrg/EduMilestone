# =============== 📌 Android & Gradle GitIgnore =============== #

# ✅ IntelliJ/Android Studio settings
*.iml
.idea/
.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/

# ✅ Gradle
.gradle/
/.gradle/
/local.properties  # Prevents machine-specific settings from being committed
/.gradle/
/captures/
.externalNativeBuild/
.cxx/

# ✅ Build output
/build/
/outputs/
/intermediates/
/out/
app/build/  # Ensure app-specific build directory is ignored
milestone/build/
milestone/milestone_modules_01/build/

# ✅ OS-specific files
.DS_Store  # MacOS
Thumbs.db  # Windows

# ✅ Dependency directories
/node_modules/  # Node.js dependencies
/venv/  # Python virtual environment

# ✅ Log files
/logs/
*.log
*.log.*

# ✅ ProGuard & mapping files
*.mapping
*.bak
*.bak.gz
/mapping.txt

# ✅ Google Services (Optional, if using Firebase)
/google-services.json
/google-services.xml
/service-account.json

# ✅ Android Lint reports
lint/intermediates/
lint/generated/
lint/reports/

# ✅ Miscellaneous IDE & System Files
*.swp
*.swo

local.properties

# ✅ Additional Android Build Directories
android/app/build/
android/.gradle/
android/.idea/
android/local.properties